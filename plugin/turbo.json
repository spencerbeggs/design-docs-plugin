{
	"$schema": "https://turborepo.com/schema.v2.json",
	"extends": ["//"],
	"tasks": {
		"build": {
			"cache": false,
			"dependsOn": ["types:check", "//#kill:otel", "validate"],
			"outputs": ["*.plugin"]
		},
		"test": {
			"cache": false,
			"outputs": []
		},
		"types:check": {
			"cache": false,
			"dependsOn": [],
			"outputLogs": "errors-only",
			"outputs": []
		},
		"validate": {
			"cache": false,
			"dependsOn": [],
			"outputs": []
		}
	}
}
