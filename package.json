{
	"name": "design-docs-plugin",
	"version": "0.1.0",
	"private": true,
	"description": "Root package for the design-docs-plugin monorepo",
	"type": "module",
	"workspaces": [".", "plugin"],
	"scripts": {
		"build": "turbo run build --log-order=grouped --log-prefix=none",
		"ci:build": "CI=\"true\" turbo run build --log-order=grouped --log-prefix=none",
		"ci:test": "CI=\"true\" bun test",
		"ci:version": "savvy-changesets version && biome format --write .",
		"commit:check": "savvy-commit check",
		"commit:init": "savvy-commit init",
		"kill:otel": "bun ./lib/scripts/kill-otel.ts",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 '**/*.{md,mdx}' --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "bun test",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit",
		"validate": "turbo run validate --log-prefix=none --log-order=grouped"
	},
	"devDependencies": {
		"@savvy-web/changesets": "^0.6.0",
		"@savvy-web/commitlint": "^0.4.3",
		"@savvy-web/lint-staged": "^0.6.2",
		"@types/bun": "1.3.9",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "7.0.0-dev.20260323.1",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"@changesets/cli": "^2.30.0",
		"@commitlint/cli": "^20.5.0",
		"@commitlint/config-conventional": "^20.5.0",
		"commitizen": "^4.3.1",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"markdownlint-cli2": "^0.22.0",
		"markdownlint-cli2-formatter-codequality": "^0.0.7",
		"turbo": "2.8.20"
	},
	"packageManager": "bun@1.3.9",
	"engines": {
		"bun": ">=1.3.9"
	},
	"engineStrict": true,
	"devEngines": {
		"runtime": [
			{
				"name": "bun",
				"version": "1.3.9",
				"onFail": "ignore"
			}
		],
		"packageManager": {
			"name": "bun",
			"version": "1.3.9",
			"onFail": "ignore"
		}
	}
}
